            <soluling:scannedcomment>0: Name of a person, 1: Number of cars</soluling:scannedcomment>
            <soluling:datatype>string</soluling:datatype>
            <soluling:rowstatus>rsInUse</soluling:rowstatus>
          </trans-unit>
          <trans-unit id="Win32\Release\Format.exe.String.Unit1.SCount2">
            <source>{0} cars will pick up {1} and {2}</source>
            <target state="final">{0} autoa hakee {1}:in ja {2}:in</target>
            <alt-trans>
              <target xml:lang="de" state="translated" state-qualifier="fuzzy-match">Autos nehmen {1} und {2} auf.</target>
              <target xml:lang="nl" state="translated" state-qualifier="fuzzy-match">Auto's zullen {0} ophalen {1} en {2}.</target>

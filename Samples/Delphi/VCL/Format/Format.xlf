              <target xml:lang="fi-FI" state="translated">Moikka {1} ja {0}!</target>
              <target xml:lang="de" state="translated" state-qualifier="fuzzy-match">Hallo {0} und {1}!</target>
              <target xml:lang="nl" state="translated" state-qualifier="fuzzy-match">Hallo {0} en {1}!</target>
              <target xml:lang="he" state="translated">שלום {0} {1}!</target>
            </alt-trans>
            <note>0: Name of the first person, 1: Name of the second person</note>
            <soluling:scannedcomment>0: Name of the first person, 1: Name of the second person</soluling:scannedcomment>
            <soluling:datatype>string</soluling:datatype>
            <soluling:rowstatus>rsInUse</soluling:rowstatus>
          </trans-unit>
          <trans-unit id="Win32\Release\Format.exe.String.Unit1.SCount">
            <source>{0} has {1} cars</source>
            <target state="final">{0}:lla on {1} autoa</target>
            <alt-trans>
              <target xml:lang="de" state="translated" state-qualifier="fuzzy-match">{0} hat {1} Autos</target>
              <target xml:lang="nl" state="translated" state-qualifier="fuzzy-match">{0} heeft {1} auto's</target>

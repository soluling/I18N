      <group id="String">
        <group id="String.Unit1">
          <trans-unit id="Win32\Release\Format.exe.String.Unit1.SHello">
            <source>Hello {0}!</source>
            <target state="final">Moi {0}!</target>
            <alt-trans>
              <target xml:lang="de" state="translated" state-qualifier="fuzzy-match">Hallo {0}!</target>
              <target xml:lang="nl" state="translated" state-qualifier="fuzzy-match">Hallo {0}!</target>
            </alt-trans>
            <note>0: Name of a person</note>
            <soluling:scannedcomment>0: Name of a person</soluling:scannedcomment>
            <soluling:datatype>string</soluling:datatype>
            <soluling:rowstatus>rsInUse</soluling:rowstatus>
          </trans-unit>
          <trans-unit id="Win32\Release\Format.exe.String.Unit1.SHello2">
            <source>Hello {0} and {1}!</source>
            <target state="final">Moi {0} ja {1}!</target>

{
  "name": "select",
  "version": "0.0.0",
  "scripts": {
    "i18n": "ng extract-i18n --format=xlf2 --output-path src/locale",
    "i18n1": "ng extract-i18n --format=xlf --output-path src/locale --out-file=messages12.xlf",
    "i18nx": "ng extract-i18n --format=xmb --output-path src/locale",
    "i18nj": "ng extract-i18n --format=json --output-path src/locale",
    "i18na": "ng extract-i18n --format=arb --output-path src/locale",
    "fi": "ng serve -c=fi -o",
    "ng": "ng",
    "start": "ng serve -o",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.2",
    "@angular/common": "^21.1.2",
    "@angular/compiler": "^21.1.2",
    "@angular/core": "^21.1.2",
    "@angular/forms": "^21.1.2",
    "@angular/localize": "^21.1.2",
    "@angular/platform-browser": "^21.1.2",
    "@angular/platform-browser-dynamic": "^21.1.2",
    "@angular/router": "^21.1.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.2",
    "@types/jasmine": "~4.3.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "typescript": "~5.9.3"
  }
